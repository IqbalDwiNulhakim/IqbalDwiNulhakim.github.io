# EmailJS Configuration
# Dapatkan credentials dari https://www.emailjs.com

# Replace dengan Public Key Anda dari EmailJS
VITE_EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY

# Replace dengan Service ID Anda dari EmailJS (Gmail Service)
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID

# Replace dengan Template ID Anda dari EmailJS
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
